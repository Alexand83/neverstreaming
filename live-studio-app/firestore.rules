rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /rooms/{roomId} {
      allow read, write: if request.auth != null;
      match /participants/{userId} {
        allow read, write: if request.auth != null;
      }
      match /chat/{msgId} {
        allow read, create: if request.auth != null;
      }
      match /signaling/{peerA}/{peerB}/{msgId} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
